// Reference global zellij config — copy to ~/.config/zellij/config.kdl and adjust as needed
// Full docs: https://zellij.dev/documentation/configuration

keybinds {
    normal {
        // Use Ctrl-a as prefix (screen/tmux-style)
        bind "Ctrl a" { SwitchToMode "Tmux"; }
    }
}

// Detach instead of quit when terminal closes (e.g. SSH disconnect)
// Keeps sessions alive for reattaching — without this, zellij kills
// the session and resurrects from saved state, losing running processes
on_force_close "detach"

// Default layout to open when starting zellij without arguments
// default_layout "flock"

// Copy to clipboard on select
copy_on_select true

// Mouse support
mouse_mode true

// Stacked panes resize with neighbors for more screen space
stacked_resize true

// Scroll buffer size
scroll_buffer_size 10000
